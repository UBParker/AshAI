# AshAI / helperAI Configuration
# Copy to .env and adjust as needed

# Server
HELPERAI_HOST=127.0.0.1
HELPERAI_PORT=8000
HELPERAI_LOG_LEVEL=info

# Default LLM Provider (ollama, openai, anthropic, gemini, claude_web)
HELPERAI_DEFAULT_PROVIDER=ollama

# Ollama (local models)
HELPERAI_OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
HELPERAI_OPENAI_API_KEY=
HELPERAI_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
HELPERAI_ANTHROPIC_API_KEY=

# Google Gemini
HELPERAI_GEMINI_API_KEY=

# ── Docker Multi-Provider Proxy (claude-cli container) ───────────────────────
# These are passed directly to the container (not prefixed with HELPERAI_).
# The proxy listens on port 8082 and routes by path prefix.
#
#   http://localhost:8082/anthropic/*  → api.anthropic.com
#   http://localhost:8082/openai/*     → api.openai.com/v1
#   http://localhost:8082/gemini/*     → generativelanguage.googleapis.com
#   http://localhost:8082/ollama/*     → OLLAMA_BASE_URL
#   http://localhost:8082/custom/X/*   → CUSTOM_X_URL
#   http://localhost:8082/*            → api.anthropic.com  (legacy compat)
#
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://host.docker.internal:11434
#
# Custom provider example (repeat pattern for more):
# CUSTOM_MISTRAL_URL=https://api.mistral.ai/v1
# CUSTOM_MISTRAL_API_KEY=
# CUSTOM_GROQ_URL=https://api.groq.com/openai/v1
# CUSTOM_GROQ_API_KEY=

# Claude Web Automation (requires playwright)
HELPERAI_CLAUDE_WEB_EMAIL=
HELPERAI_CLAUDE_WEB_PASSWORD=
HELPERAI_CLAUDE_WEB_HEADLESS=true
HELPERAI_CLAUDE_WEB_TIMEOUT=30000

# Database
HELPERAI_DATABASE_URL=sqlite+aiosqlite:///./helperai.db

# Sandbox
HELPERAI_SANDBOX_ALLOWED_DIRS=.
HELPERAI_SANDBOX_MAX_FILE_SIZE=10485760
HELPERAI_SANDBOX_PROCESS_TIMEOUT=120

# Auth (optional - disabled by default for local use)
HELPERAI_AUTH_ENABLED=false
HELPERAI_AUTH_SECRET_KEY=change-me-in-production