{
  "manifest_version": 3,
  "name": "Claude AshAI Bridge",
  "version": "1.0",
  "description": "Bridge between Claude.ai and AshAI",
  "permissions": [
    "webRequest",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "https://*.claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.claude.ai/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}