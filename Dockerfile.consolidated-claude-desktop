# AshAI Claude Desktop — Ubuntu-based VNC/Desktop container with browser automation.
# Consolidates: Dockerfile.claude-code, Dockerfile.vnc-claude, Dockerfile.vnc-browser,
#               Dockerfile.claude-session, Dockerfile.claude-cli
#
# Build variants:
#   Playwright + Chromium:  docker build -f Dockerfile.consolidated-claude-desktop -t ashai-vnc-claude .
#   Firefox + Playwright:   docker build -f Dockerfile.consolidated-claude-desktop --build-arg BROWSER=firefox -t ashai-vnc-firefox .
#   Desktop app mode:       docker build -f Dockerfile.consolidated-claude-desktop --build-arg WITH_ELECTRON=true -t ashai-claude-desktop .
#   CLI + SSH mode:         docker build -f Dockerfile.consolidated-claude-desktop --build-arg WITH_SSH=true --build-arg WITH_NODEJS=true -t ashai-claude-ssh .
#   Session API only:       docker build -f Dockerfile.consolidated-claude-desktop --build-arg SESSION_ONLY=true -t ashai-session .

FROM ubuntu:22.04

ARG BROWSER=chromium
ARG WITH_ELECTRON=false
ARG WITH_SSH=false
ARG WITH_NODEJS=false
ARG SESSION_ONLY=false

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=UTC \
    DISPLAY=:99

# --- Minimal base (always needed) ---
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    curl \
    wget \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# --- Python virtual environment (no --break-system-packages needed) ---
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --no-cache-dir aiohttp

# --- VNC + X11 stack (conditional, skip for session-only) ---
RUN if [ "$SESSION_ONLY" != "true" ]; then \
    apt-get update && apt-get install -y --no-install-recommends \
        xvfb x11vnc fluxbox xterm xclip \
    && rm -rf /var/lib/apt/lists/*; \
    fi

# --- Playwright + browser deps (conditional) ---
RUN if [ "$SESSION_ONLY" != "true" ]; then \
    pip install --no-cache-dir playwright && \
    apt-get update && apt-get install -y --no-install-recommends \
        libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
        libdbus-1-3 libatspi2.0-0 libx11-6 libxcomposite1 libxdamage1 \
        libxext6 libxfixes3 libxrandr2 libgbm1 libxcb1 libxkbcommon0 \
        libpango-1.0-0 libcairo2 libasound2 \
    && rm -rf /var/lib/apt/lists/*; \
    fi

# --- Install browser via Playwright (conditional) ---
RUN if [ "$SESSION_ONLY" != "true" ]; then \
    if [ "$BROWSER" = "firefox" ]; then \
        playwright install firefox && playwright install-deps firefox; \
    else \
        playwright install chromium && playwright install-deps chromium; \
    fi; \
    fi

# --- Electron/Desktop app deps (conditional) ---
RUN if [ "$WITH_ELECTRON" = "true" ]; then \
    apt-get update && apt-get install -y --no-install-recommends \
        gnupg libgtk-3-0 libxss1 libxtst6 xdg-utils libsecret-1-0 \
    && rm -rf /var/lib/apt/lists/*; \
    fi

# --- Node.js (conditional, for Claude Code CLI) ---
RUN if [ "$WITH_NODEJS" = "true" ]; then \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*; \
    fi

# --- SSH server (conditional) ---
RUN if [ "$WITH_SSH" = "true" ]; then \
    apt-get update && apt-get install -y --no-install-recommends \
        openssh-server supervisor sudo git \
    && rm -rf /var/lib/apt/lists/* && \
    mkdir -p /var/run/sshd && \
    sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin no/' /etc/ssh/sshd_config && \
    sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config; \
    fi

# --- Create non-root user ---
RUN useradd -m -s /bin/bash claude && \
    usermod -aG audio,video claude

# Setup directories
RUN mkdir -p /app /home/claude/.vnc && \
    chown -R claude:claude /app /home/claude

WORKDIR /app

# --- VNC password setup (conditional) ---
RUN if [ "$SESSION_ONLY" != "true" ]; then \
    x11vnc -storepasswd changeme /home/claude/.vnc/passwd && \
    chown -R claude:claude /home/claude/.vnc; \
    fi

# Create unified entrypoint
RUN printf '#!/bin/bash\nset -e\n\nMODE="${1:-auto}"\n\nstart_vnc() {\n    Xvfb :99 -screen 0 1280x720x24 &\n    sleep 2\n    fluxbox &\n    x11vnc -display :99 -forever -usepw -shared -rfbport 5900 &\n    echo "VNC server started on port 5900"\n}\n\ncase "$MODE" in\n    session)\n        echo "Starting session API server..."\n        exec python3 /app/claude-session-api.py\n        ;;\n    vnc)\n        start_vnc\n        exec python3 /app/vnc-claude-agent.py\n        ;;\n    desktop)\n        start_vnc\n        exec /home/claude/entrypoint.sh\n        ;;\n    ssh)\n        sudo /usr/sbin/sshd\n        exec python3 /app/claude-terminal-controller.py\n        ;;\n    auto)\n        if [ -f /app/claude-session-api.py ]; then\n            exec python3 /app/claude-session-api.py\n        elif [ -f /app/vnc-claude-agent.py ]; then\n            start_vnc\n            exec python3 /app/vnc-claude-agent.py\n        else\n            echo "No known entrypoint found. Provide a command."\n            exec "$@"\n        fi\n        ;;\n    *)\n        exec "$@"\n        ;;\nesac\n' > /app/entrypoint.sh && \
    chmod +x /app/entrypoint.sh

# Expose common ports
EXPOSE 5900 8080 8081

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8080/health 2>/dev/null || curl -f http://localhost:8081/health 2>/dev/null || exit 1

USER claude

ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["auto"]
