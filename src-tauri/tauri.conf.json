{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri2/tauri.conf.json",
  "productName": "AshAI",
  "version": "0.1.0",
  "identifier": "com.ashai.app",
  "build": {
    "frontendDist": "../src/frontend/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../src/frontend && npm run dev",
    "beforeBuildCommand": "cd ../src/frontend && npm run build"
  },
  "app": {
    "title": "AshAI",
    "windows": [
      {
        "title": "AshAI",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ashai-server"
    ]
  }
}
