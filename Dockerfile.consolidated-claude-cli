# AshAI Claude CLI — Alpine-based Claude Code CLI container.
#
# Build:
#   docker build -f Dockerfile.consolidated-claude-cli -t ashai-claude-cli .
#
# Provider API keys (pass at runtime via -e or docker-compose env):
#   ANTHROPIC_API_KEY   — Anthropic  → proxied at /anthropic/* and legacy /*
#   OPENAI_API_KEY      — OpenAI     → proxied at /openai/*
#   GEMINI_API_KEY      — Gemini     → proxied at /gemini/*
#   OLLAMA_BASE_URL     — Ollama     → proxied at /ollama/* (default: host.docker.internal:11434)
#
# Custom providers (arbitrary number):
#   CUSTOM_<NAME>_URL       — base URL
#   CUSTOM_<NAME>_API_KEY   — optional API key (Bearer auth)
#   → proxied at /custom/<name>/*
#
# Proxy listens on PROXY_PORT (default 8082).

FROM node:20-alpine

# --- Base packages ---
RUN apk add --no-cache \
    python3 \
    py3-pip \
    py3-virtualenv \
    curl \
    bash \
    htop \
    openssh-server \
    git \
    sudo \
    build-base \
    coreutils

# Configure sshd
RUN mkdir -p /var/run/sshd \
    && ssh-keygen -A \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin no/' /etc/ssh/sshd_config \
    && sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config

# Install Claude CLI and Gemini CLI
RUN npm install -g @anthropic-ai/claude-code @google/gemini-cli

# Create non-root user with sudo access
RUN adduser -D -s /bin/bash claude \
    && echo "claude:claude" | chpasswd \
    && addgroup claude wheel \
    && echo '%wheel ALL=(ALL) NOPASSWD: ALL' >> /etc/sudoers

# --- Python virtual environment ---
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir aiohttp requests

# Copy terminal controller (API server for cli_agent provider)
COPY --chown=claude:claude cli-terminal-controller.py /home/claude/

# Copy multi-provider API proxy (routes /anthropic, /openai, /gemini, /ollama, /custom/*)
COPY --chown=claude:claude multi-provider-proxy.py /home/claude/

# Copy bridge tools to /app
COPY --chown=claude:claude claude-tool-bridge.py /app/
COPY --chown=claude:claude report_to_eve.py /app/
COPY --chown=claude:claude ashai-tools/ /app/ashai-tools/

# Copy backend API code
COPY --chown=claude:claude pyproject.toml /app/
COPY --chown=claude:claude README.md /app/
COPY --chown=claude:claude src/ /app/src/
COPY --chown=claude:claude plugins/ /app/plugins/

# Install backend API dependencies (as root for system packages)
USER root
RUN cd /app && pip install --no-cache-dir -e . && \
    pip install --no-cache-dir docker && \
    apk del py3-pip py3-virtualenv
USER claude

# Setup directories (/app/workspace is expected to be a host mount)
RUN mkdir -p /home/claude/.config/@anthropic-ai/claude-code \
    && mkdir -p /home/claude/.cache \
    && mkdir -p /home/claude/.ssh \
    && mkdir -p /tmp/.X11-unix \
    && mkdir -p /app/workspace \
    && mkdir -p /app/data \
    && chown -R claude:claude /home/claude /app \
    && chmod 1777 /tmp/.X11-unix

# Create entrypoint script
RUN cat > /home/claude/entrypoint.sh << 'ENTRYPOINT_EOF'
#!/bin/sh
set -e

# Start sshd
sudo /usr/sbin/sshd

# Load auth file if mounted
if [ -f /tmp/claude-auth.json ]; then
    cp /tmp/claude-auth.json /home/claude/.config/@anthropic-ai/claude-code/auth.json
    chmod 600 /home/claude/.config/@anthropic-ai/claude-code/auth.json
fi

# Start multi-provider proxy if any API key is configured
# Proxy runs on port 8082 (PROXY_PORT) and handles all providers:
#   /anthropic/* → api.anthropic.com  (ANTHROPIC_API_KEY)
#   /openai/*    → api.openai.com/v1  (OPENAI_API_KEY)
#   /gemini/*    → generativelanguage.googleapis.com  (GEMINI_API_KEY)
#   /ollama/*    → OLLAMA_BASE_URL    (no auth)
#   /custom/X/*  → CUSTOM_X_URL      (CUSTOM_X_API_KEY)
#   /*           → api.anthropic.com  (legacy compat)
if [ -n "$ANTHROPIC_API_KEY" ] || [ -n "$OPENAI_API_KEY" ] || [ -n "$GEMINI_API_KEY" ] || [ -n "$OLLAMA_BASE_URL" ]; then
    echo "Starting multi-provider proxy on port ${PROXY_PORT:-8082}..."
    python3 /home/claude/multi-provider-proxy.py &
else
    echo "WARNING: No provider API keys set — proxy not started (set ANTHROPIC_API_KEY, OPENAI_API_KEY, GEMINI_API_KEY, or OLLAMA_BASE_URL)"
fi

# Start backend API
echo "Starting Backend API on port 8000..."
cd /app
export HELPERAI_DATABASE_URL=sqlite+aiosqlite:////app/data/helperai.db
export HELPERAI_PLUGINS_DIR=/app/plugins
export HELPERAI_HOST=0.0.0.0
export HELPERAI_PORT=8000
export HELPERAI_ANTHROPIC_BASE_URL=http://localhost:8082
export HELPERAI_ANTHROPIC_API_KEY=proxy
export HELPERAI_DEFAULT_PROVIDER=cli_agent
export HELPERAI_DEFAULT_MODEL=sonnet
export HELPERAI_EVE_PROVIDER=anthropic
export HELPERAI_EVE_MODEL=claude-opus-4-6
# Disable Ollama since we're using Claude CLI
export HELPERAI_OLLAMA_BASE_URL=""
python3 -m helperai &
BACKEND_PID=$!

# Wait for backend to be ready
echo "Waiting for backend API to be ready..."
for i in $(seq 1 30); do
    if curl -f http://localhost:8000/api/health >/dev/null 2>&1; then
        echo "Backend API is ready!"
        break
    fi
    sleep 1
done

case "$1" in
    server|"")
        echo "Starting CLI Agent Controller on port 8081..."
        # Run controller in foreground, backend continues in background
        exec python3 /home/claude/cli-terminal-controller.py
        ;;
    proxy-only)
        echo "Running proxy only (no terminal controller)..."
        wait $BACKEND_PID
        ;;
    *)
        exec "$@"
        ;;
esac
ENTRYPOINT_EOF
RUN chmod +x /home/claude/entrypoint.sh

USER claude
WORKDIR /home/claude

EXPOSE 8000 8081 8082 22

# Health check: terminal controller primary, proxy secondary
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8081/api/status 2>/dev/null || curl -f http://localhost:8082/health 2>/dev/null || exit 1

ENTRYPOINT ["/home/claude/entrypoint.sh"]
CMD ["server"]
