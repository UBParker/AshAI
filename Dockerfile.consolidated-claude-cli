# AshAI Claude CLI — Alpine-based Claude Code CLI container.
# Consolidates: Dockerfile.claude-browser, Dockerfile.claude-x11, Dockerfile.claude-final, Dockerfile.claude-authenticated
#
# Build variants:
#   Minimal (no browser):     docker build -f Dockerfile.consolidated-claude-cli -t ashai-claude-cli .
#   With browser + VNC:       docker build -f Dockerfile.consolidated-claude-cli --build-arg WITH_BROWSER=true --build-arg WITH_VNC=true -t ashai-claude-browser .
#   With browser (X11 only):  docker build -f Dockerfile.consolidated-claude-cli --build-arg WITH_BROWSER=true -t ashai-claude-x11 .

FROM node:20-alpine

ARG WITH_BROWSER=false
ARG WITH_VNC=false

# --- Base packages (always needed) ---
RUN apk add --no-cache \
    python3 \
    py3-pip \
    py3-virtualenv \
    curl

# --- Browser packages (conditional) ---
RUN if [ "$WITH_BROWSER" = "true" ]; then \
    apk add --no-cache \
        chromium xvfb xauth dbus \
        ttf-freefont font-noto-emoji \
        mesa-dri-gallium udev; \
    fi

# --- VNC packages (conditional, requires WITH_BROWSER) ---
RUN if [ "$WITH_VNC" = "true" ]; then \
    apk add --no-cache x11vnc; \
    fi

# Install Claude CLI
RUN npm install -g @anthropic-ai/claude-code

# Create non-root user
RUN adduser -D -s /bin/sh claude

# --- Python virtual environment (no --break-system-packages needed) ---
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --no-cache-dir aiohttp

# Copy CLI-based API server
COPY --chown=claude:claude claude_cli_server.py /home/claude/

# Setup directories
RUN mkdir -p /home/claude/.config/@anthropic-ai/claude-code \
    && mkdir -p /home/claude/.cache \
    && mkdir -p /tmp/.X11-unix \
    && chown -R claude:claude /home/claude \
    && chmod 1777 /tmp/.X11-unix

# Create entrypoint script that handles all variants
RUN printf '#!/bin/sh\nset -e\n\n# Load auth file if mounted\nif [ -f /tmp/claude-auth.json ]; then\n    cp /tmp/claude-auth.json /home/claude/.config/@anthropic-ai/claude-code/auth.json\n    chmod 600 /home/claude/.config/@anthropic-ai/claude-code/auth.json\nfi\n\ncase "$1" in\n    auth)\n        echo "Starting X11 server for authentication..."\n        Xvfb :99 -screen 0 1280x1024x24 &\n        export DISPLAY=:99\n        sleep 2\n        if command -v x11vnc >/dev/null 2>&1; then\n            x11vnc -display :99 -forever -nopw -shared -rfbport 5900 &\n        fi\n        echo "Launching Claude CLI authentication..."\n        claude auth\n        echo "Authentication complete!"\n        ;;\n    server|"")\n        echo "Starting Claude CLI server..."\n        exec python3 /home/claude/claude_cli_server.py\n        ;;\n    *)\n        exec "$@"\n        ;;\nesac\n' > /home/claude/entrypoint.sh && \
    chmod +x /home/claude/entrypoint.sh

USER claude
WORKDIR /home/claude

EXPOSE 8000

# Health check for the API server
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8000/health 2>/dev/null || exit 1

ENTRYPOINT ["/home/claude/entrypoint.sh"]
CMD ["server"]
