# AshAI Claude CLI — Alpine-based Claude Code CLI container.
#
# Build:
#   docker build -f Dockerfile.consolidated-claude-cli -t ashai-claude-cli .

FROM node:20-alpine

# --- Base packages ---
RUN apk add --no-cache \
    python3 \
    py3-pip \
    py3-virtualenv \
    curl \
    bash \
    htop \
    openssh-server \
    git \
    sudo

# Configure sshd
RUN mkdir -p /var/run/sshd \
    && ssh-keygen -A \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin no/' /etc/ssh/sshd_config \
    && sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config

# Install Claude CLI
RUN npm install -g @anthropic-ai/claude-code

# Create non-root user with sudo access
RUN adduser -D -s /bin/bash claude \
    && echo "claude:claude" | chpasswd \
    && addgroup claude wheel \
    && echo '%wheel ALL=(ALL) NOPASSWD: ALL' >> /etc/sudoers

# --- Python virtual environment ---
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --no-cache-dir aiohttp requests \
    && apk del py3-pip py3-virtualenv

# Copy terminal controller (API server for claude_terminal provider)
COPY --chown=claude:claude claude-terminal-controller.py /home/claude/

# Copy bridge tools to /app
COPY --chown=claude:claude claude-tool-bridge.py /app/
COPY --chown=claude:claude report_to_eve.py /app/
COPY --chown=claude:claude ashai-tools/ /app/ashai-tools/

# Setup directories (/app/workspace is expected to be a host mount)
RUN mkdir -p /home/claude/.config/@anthropic-ai/claude-code \
    && mkdir -p /home/claude/.cache \
    && mkdir -p /home/claude/.ssh \
    && mkdir -p /tmp/.X11-unix \
    && mkdir -p /app/workspace \
    && chown -R claude:claude /home/claude /app \
    && chmod 1777 /tmp/.X11-unix

# Create entrypoint script
RUN printf '#!/bin/sh\nset -e\n\n# Start sshd\nsudo /usr/sbin/sshd\n\n# Load auth file if mounted\nif [ -f /tmp/claude-auth.json ]; then\n    cp /tmp/claude-auth.json /home/claude/.config/@anthropic-ai/claude-code/auth.json\n    chmod 600 /home/claude/.config/@anthropic-ai/claude-code/auth.json\nfi\n\ncase "$1" in\n    server|"")\n        echo "Starting Claude Terminal Controller on port 8081..."\n        exec python3 /home/claude/claude-terminal-controller.py\n        ;;\n    *)\n        exec "$@"\n        ;;\nesac\n' > /home/claude/entrypoint.sh && \
    chmod +x /home/claude/entrypoint.sh

USER claude
WORKDIR /home/claude

EXPOSE 8081 22

# Health check for the terminal controller
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8081/api/status 2>/dev/null || exit 1

ENTRYPOINT ["/home/claude/entrypoint.sh"]
CMD ["server"]
