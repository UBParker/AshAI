# AshAI Base Image — shared foundation for all AshAI containers.
# Python 3.11-slim with non-root user, health check, and common dependencies.
#
# This is a multi-stage base used by:
#   - Dockerfile.main (gateway)
#   - Dockerfile.playwright (gateway + web automation)
#   - Dockerfile.vnc-claude (VNC desktop + browser automation)
#   - Dockerfile.vnc-browser (Alpine CLI + optional browser/VNC)

FROM python:3.11-slim AS base

# Common system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user (override name via ARG in child images)
ARG APP_USER=ashai
ARG APP_HOME=/home/${APP_USER}
RUN groupadd -r ${APP_USER} && \
    useradd -r -g ${APP_USER} -G audio,video -m -d ${APP_HOME} ${APP_USER}

# Python virtual environment
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1

# Default health check (child images should override CMD path)
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:${HEALTH_PORT:-8080}/health 2>/dev/null || exit 1
